# Attention Terminal — environment variables
# Copy to .env and fill in. Secrets come from 1Password (see CLAUDE.md).

# ClickHouse Cloud
CLICKHOUSE_URL=https://kmmno2h0ec.us-central1.gcp.clickhouse.cloud:8443
CLICKHOUSE_HOST=kmmno2h0ec.us-central1.gcp.clickhouse.cloud
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default

# GitHub (required for REST activity poller + on-demand drilldown enrichment)
GITHUB_TOKEN=

# OpenAI (required for the default gpt-5.1 agent model)
OPENAI_API_KEY=

# Attention agent model switch (issue #79 track #85)
# Default: "openai:gpt-5.1". Switch to "glm:glm-5.2" to test glm-5.2 via Ollama.
ATTENTION_AGENT_MODEL=openai:gpt-5.1

# GLM provider (Ollama local — OpenAI-compatible endpoint)
# Used when ATTENTION_AGENT_MODEL=glm:glm-5.2
GLM_BASE_URL=http://localhost:11434/v1
GLM_API_KEY=ollama

# Trigger.dev
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_REF=proj_inafrgiuiixqgirbqbww

# Trigger.dev & OpenTelemetry Telemetry Exporters
# CLICKHOUSE_OTLP_URL: ClickHouse Cloud HTTP endpoint (e.g. https://<instance>.clickhouse.cloud:8443)
# CLICKHOUSE_OTLP_AUTH_TOKEN: Generated from ClickHouse Cloud Console (Settings -> Access Tokens -> OpenTelemetry)
# or Base64-encoded credentials: base64(user:password)
CLICKHOUSE_OTLP_URL=https://kmmno2h0ec.us-central1.gcp.clickhouse.cloud:8443
CLICKHOUSE_OTLP_AUTH_TOKEN=